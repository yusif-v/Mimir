# Mimir Configuration
# Place this file at ~/.mimir/config.yaml

# All paths default to ~/.mimir/ — override only what you need
# home_dir: ~/.mimir
# investigations: ~/.mimir/investigations
# tools: ~/.mimir/tools
# plugins: ~/.mimir/plugins
# cache: ~/.mimir/cache
# logs: ~/.mimir/logs
# log_file: ~/.mimir/logs/mimir.log
# history: ~/.mimir/.history

log_level: INFO
